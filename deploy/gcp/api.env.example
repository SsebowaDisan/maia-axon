APP_NAME=Maia Axon
DEBUG=false
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://DB_USER:DB_PASSWORD@/DB_NAME?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME

REDIS_URL=redis://REDIS_HOST:6379/0
CELERY_BROKER_URL=redis://REDIS_HOST:6379/1

S3_ENDPOINT_URL=https://storage.googleapis.com
S3_PUBLIC_URL=https://storage.googleapis.com
S3_ACCESS_KEY=GCS_HMAC_ACCESS_KEY
S3_SECRET_KEY=GCS_HMAC_SECRET
S3_BUCKET_NAME=YOUR_BUCKET_NAME

OPENAI_API_KEY=YOUR_OPENAI_API_KEY
GLMOCR_API_KEY=YOUR_GLMOCR_API_KEY
GLMOCR_DEPLOYMENT=cloud

JWT_SECRET_KEY=SET_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
